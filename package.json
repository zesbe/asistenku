{
  "name": "asistenku",
  "version": "0.2.0",
  "description": "Asistenku — multi-provider AI coding CLI dengan file-based memory, open source, bikinan anak Indonesia 🇮🇩",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "asistenku": "./dist/asistenku"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run src/cli.ts",
    "build": "bun build --compile --minify --sourcemap --target=bun src/cli.ts --outfile dist/asistenku",
    "build:all": "bun run build:linux && bun run build:mac && bun run build:win",
    "build:linux": "bun build --compile --minify --target=bun-linux-x64 src/cli.ts --outfile dist/asistenku-linux-x64",
    "build:linux-arm": "bun build --compile --minify --target=bun-linux-arm64 src/cli.ts --outfile dist/asistenku-linux-arm64",
    "build:mac": "bun build --compile --minify --target=bun-darwin-x64 src/cli.ts --outfile dist/asistenku-darwin-x64",
    "build:mac-arm": "bun build --compile --minify --target=bun-darwin-arm64 src/cli.ts --outfile dist/asistenku-darwin-arm64",
    "build:win": "bun build --compile --minify --target=bun-windows-x64 src/cli.ts --outfile dist/asistenku-windows-x64.exe",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "test": "bun test"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "claude",
    "gpt",
    "gemini",
    "multi-provider",
    "mcp",
    "indonesia",
    "terminal",
    "agent",
    "tui"
  ],
  "author": "zesbe <yudiharyanto41@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/zesbe/asistenku",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zesbe/asistenku.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/deepseek": "^2.0.34",
    "@ai-sdk/google": "^3.0.70",
    "@ai-sdk/openai": "^3.0.63",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.176",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cli-markdown": "^3.5.1",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "diff-lines": "^1.1.1",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "globby": "^16.2.0",
    "gray-matter": "^4.0.3",
    "ink": "4",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  }
}
