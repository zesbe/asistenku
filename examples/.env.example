# asistenku environment variables
# Copy to ~/.asistenku/.env or set in shell profile

# ─── Providers ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx
OPENAI_API_KEY=sk-proj-xxx
GEMINI_API_KEY=AI-xxx
# or GOOGLE_GENERATIVE_AI_API_KEY=AI-xxx
DEEPSEEK_API_KEY=sk-xxx
GROQ_API_KEY=gsk_xxx
OPENROUTER_API_KEY=sk-or-xxx

# ─── Defaults ────────────────────────────────────────────────
ASISTENKU_PROVIDER=anthropic
ASISTENKU_MODEL=claude-sonnet-4-5-20250929
ASISTENKU_PERMISSION_MODE=ask

# ─── MCP Server Secrets ─────────────────────────────────────
GITHUB_TOKEN=ghp_xxx
BRAVE_API_KEY=BSA-xxx
SLACK_BOT_TOKEN=xoxb-xxx

# ─── Ollama (local LLM) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Debug ──────────────────────────────────────────────────
DEBUG=asistenku:*
